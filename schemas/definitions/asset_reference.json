{
  "$id": "https://raw.githubusercontent.com/Monster-Train-2-Modding-Group/Trainworks-Reloaded/refs/heads/main/schemas/definitions/asset_reference.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "oneOf": [
    {
      "$ref": "../definitions/reference.json"
    },
    {
      "type": "string",
      "pattern": "[0-9a-fA-F]+",
      "minLength": 32,
      "maxLength": 32
    },
    {
      "type": "object",
      "required": [ "asset_guid" ],
      "properties": {
        "asset_name": {
          "type": "string",
          "description": "Human readable asset path."
        },
        "asset_guid": {
          "type": "string",
          "pattern": "[0-9a-fA-F]+",
          "minLength": 32,
          "maxLength": 32,
          "description": "Required Asset GUID to access content from the base game."
        }
      }
    }
  ]
}