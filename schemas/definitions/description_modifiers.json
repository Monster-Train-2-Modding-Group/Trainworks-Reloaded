{
  "$id": "https://raw.githubusercontent.com/Monster-Train-2-Modding-Group/Trainworks-Reloaded/refs/heads/main/schemas/definitions/description_modifiers.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["name", "text_formats"],
  "properties": {
    "name": {
      "oneOf": [
        {
          "type": "string",
          "enum": [
            "ArtifactCountScalingModifier",
            "CardCountDescriptionModifier",
            "CardPoolCountDescriptionModifier",
            "HistoriansRazorDescriptionModifier",
            "RelicCountDescriptionModifier"
          ]
        },
        {
          "$ref": "../definitions/reference.json"
        }
      ],
      "description": "DescriptionModifier class name, This should be a class inheriting from DescriptionModifier."
    },
    "param_bool": {
      "type": "boolean",
      "description": "Boolean parameter."
    },
    "param_bool_2": {
      "type": "boolean",
      "description": "Boolean parameter."
    },
    "param_card_pool": {
      "$ref": "../definitions/card_pool.json",
      "description": "Reference to CardPool."
    },
    "param_card_rarity_type": {
      "$ref": "../definitions/rarity.json",
      "description": "Card Rarity Type parameter."
    },
    "param_card_type": {
      "$ref": "../definitions/card_type.json",
      "description": "Card type parameter.",
      "default": "invalid"
    },
    "param_subtype": {
      "$ref": "../definitions/subtype.json",
      "description": "Reference to Character subtype.",
      "default": "SubtypesData_None"
    },
    "param_float": {
      "type": "number",
      "description": "Float parameter."
    },
    "param_int": {
      "type": "integer",
      "description": "Integer parameter."
    },
    "param_string": {
      "type": "string",
      "description": "String parameter.",
      "default": ""
    },
    "text_formats": {
      "$ref": "../definitions/parse_term.json",
      "description": "Localizated text for the format key which gets appended to the Collectable Relics description."
    }
  }
}